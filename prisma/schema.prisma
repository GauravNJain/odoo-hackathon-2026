generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String?  // for credentials auth
  avatar    String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  trips     Trip[]
}

model Trip {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  startDate   DateTime
  endDate     DateTime
  coverImage  String?
  isPublic    Boolean  @default(false)
  shareToken  String?  @unique

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  stops       Stop[]
  expenses    Expense[]
  notes       Note[]
  checklist   ChecklistItem[]
}

model Stop {
  id        String     @id @default(cuid())
  tripId    String
  city      String
  country   String?
  startDate DateTime
  endDate   DateTime
  order     Int

  trip      Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  activities Activity[]
  notes     Note[]
}

model Activity {
  id          String  @id @default(cuid())
  stopId      String
  name        String
  description String?
  category    String
  cost        Float?
  duration    Int?
  imageUrl    String?

  stop        Stop    @relation(fields: [stopId], references: [id], onDelete: Cascade)
}

model Expense {
  id        String   @id @default(cuid())
  tripId    String
  title     String
  amount    Float
  category  String
  date      DateTime

  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model Note {
  id        String   @id @default(cuid())
  tripId    String?
  stopId    String?
  title     String
  content   String
  createdAt DateTime @default(now())

  trip      Trip?    @relation(fields: [tripId], references: [id])
  stop      Stop?    @relation(fields: [stopId], references: [id])
}

model ChecklistItem {
  id        String  @id @default(cuid())
  tripId    String
  item      String
  category  String?
  isPacked  Boolean @default(false)

  trip      Trip    @relation(fields: [tripId], references: [id], onDelete: Cascade)
}

model City {
  id         String @id @default(cuid())
  name       String @unique
  country    String
  costIndex  Float?
  imageUrl   String?
}
